generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum WarehouseType {
  STOCK
  PRODUCTION_REPAIR
  QC
  READY
  SHIPPING
}

enum ReceivingType {
  NEW_GOODS
  CLAIM
  REPAIR
  PARTS
  RETURN
}

enum OrderChannel {
  SHOPEE
  LAZADA
  TIKTOK
  LINE
  FACEBOOK
  WALK_IN
  CLAIM
  EXCHANGE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PICKING
  PACKING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum StockMovementType {
  RECEIVE
  ISSUE
  TRANSFER
  ADJUST_IN
  ADJUST_OUT
  RETURN_IN
  RETURN_OUT
  ASSEMBLY_CONSUME
  ASSEMBLY_PRODUCE
  DISASSEMBLY_CONSUME
  DISASSEMBLY_PRODUCE
  QC_PASS
  QC_FAIL
  SCRAP
}

enum QcResult {
  PASS
  FAIL
  CONDITIONAL_PASS
  PENDING
}

enum UserRole {
  SUPERADMIN
  ADMIN
  RECEIVING
  PRODUCTION
  QC
  WAREHOUSE
  SHIPPING
  AFTER_SALES
  READONLY
}

enum NotificationType {
  LOW_STOCK
  RECEIVING_ALERT
  ORDER_READY
  QC_REQUIRED
  SHIPMENT_DELAY
  SYSTEM
}

enum LotStatus {
  ACTIVE
  QUARANTINE
  CONSUMED
  EXPIRED
  SCRAPPED
}

enum BinStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  BLOCKED
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  supabase_id  String   @unique
  email        String   @unique
  full_name    String
  display_name String?
  role         UserRole @default(READONLY)
  department   String?
  phone        String?
  avatar_url   String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  receiving_jobs  ReceivingJob[]
  qc_records      QcRecord[]
  stock_movements StockMovement[]
  orders_handled  Order[]
  production_jobs ProductionJob[]
  notifications   Notification[]
  audit_logs      AuditLog[]
  shipments       Shipment[]

  @@map("users")
}

// ─── LOCATION HIERARCHY ──────────────────────────────────────────────────────

model Warehouse {
  id         String        @id @default(cuid())
  code       String        @unique
  name       String
  name_th    String?
  type       WarehouseType
  address    String?
  is_active  Boolean       @default(true)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  zones Zone[]

  @@map("warehouses")
}

model Zone {
  id           String    @id @default(cuid())
  warehouse_id String
  code         String
  name         String
  name_th      String?
  capacity     Int?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  warehouse Warehouse @relation(fields: [warehouse_id], references: [id])
  bins      Bin[]

  @@unique([warehouse_id, code])
  @@map("zones")
}

model Bin {
  id          String    @id @default(cuid())
  zone_id     String
  code        String
  name        String?
  status      BinStatus @default(AVAILABLE)
  max_weight  Decimal?
  max_volume  Decimal?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  zone        Zone        @relation(fields: [zone_id], references: [id])
  stock_items StockItem[]

  @@unique([zone_id, code])
  @@map("bins")
}

// ─── PRODUCT CATALOGUE ───────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  parent_id   String?
  code        String     @unique
  name        String
  name_th     String?
  description String?
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id                String   @id @default(cuid())
  category_id       String?
  sku               String   @unique
  barcode           String?  @unique
  name              String
  name_th           String?
  description       String?
  unit              String   @default("PCS")
  unit_weight       Decimal?
  unit_volume       Decimal?
  cost_price        Decimal?
  sale_price        Decimal?
  allow_sale        Boolean  @default(true)
  allow_purchase    Boolean  @default(true)
  allow_repair      Boolean  @default(false)
  allow_claim       Boolean  @default(false)
  allow_return      Boolean  @default(false)
  allow_assembly    Boolean  @default(false)
  allow_disassembly Boolean  @default(false)
  allow_qc          Boolean  @default(true)
  allow_certify     Boolean  @default(false)
  min_stock_qty     Int      @default(0)
  reorder_qty       Int      @default(0)
  image_url         String?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  category        Category?       @relation(fields: [category_id], references: [id])
  lots            Lot[]
  bom_parents     BomLine[]       @relation("BomParent")
  bom_components  BomLine[]       @relation("BomComponent")
  stock_items     StockItem[]
  order_lines     OrderLine[]
  receiving_lines ReceivingLine[]
  stock_movements StockMovement[]
  alert_rule      StockAlertRule?

  @@map("products")
}

model BomLine {
  id           String   @id @default(cuid())
  parent_id    String
  component_id String
  qty_required Decimal
  unit         String   @default("PCS")
  notes        String?
  created_at   DateTime @default(now())

  parent    Product @relation("BomParent",    fields: [parent_id],    references: [id])
  component Product @relation("BomComponent", fields: [component_id], references: [id])

  @@unique([parent_id, component_id])
  @@map("bom_lines")
}

// ─── LOT / BATCH ─────────────────────────────────────────────────────────────

model Lot {
  id              String    @id @default(cuid())
  product_id      String
  lot_number      String    @unique
  barcode         String    @unique
  status          LotStatus @default(ACTIVE)
  manufactured_at DateTime?
  expires_at      DateTime?
  supplier_ref    String?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  product         Product         @relation(fields: [product_id], references: [id])
  stock_items     StockItem[]
  receiving_lines ReceivingLine[]
  movements       StockMovement[]

  @@map("lots")
}

// ─── STOCK ───────────────────────────────────────────────────────────────────

model StockItem {
  id           String   @id @default(cuid())
  product_id   String
  lot_id       String
  bin_id       String
  qty_on_hand  Decimal  @default(0)
  qty_reserved Decimal  @default(0)
  updated_at   DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id])
  lot     Lot     @relation(fields: [lot_id],     references: [id])
  bin     Bin     @relation(fields: [bin_id],     references: [id])

  @@unique([product_id, lot_id, bin_id])
  @@map("stock_items")
}

model StockMovement {
  id             String            @id @default(cuid())
  product_id     String
  lot_id         String?
  from_bin_id    String?
  to_bin_id      String?
  movement_type  StockMovementType
  qty            Decimal
  reference_type String?
  reference_id   String?
  notes          String?
  performed_by   String
  performed_at   DateTime          @default(now())

  product Product @relation(fields: [product_id],  references: [id])
  lot     Lot?    @relation(fields: [lot_id],       references: [id])
  user    User    @relation(fields: [performed_by], references: [id])

  @@index([product_id])
  @@index([lot_id])
  @@index([reference_id])
  @@index([performed_at])
  @@map("stock_movements")
}

// ─── SUPPLIERS ───────────────────────────────────────────────────────────────

model Supplier {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  name_th      String?
  contact_name String?
  phone        String?
  email        String?
  address      String?
  tax_id       String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  receiving_jobs ReceivingJob[]

  @@map("suppliers")
}

// ─── RECEIVING ───────────────────────────────────────────────────────────────

model ReceivingJob {
  id             String         @id @default(cuid())
  job_number     String         @unique
  receiving_type ReceivingType
  supplier_id    String?
  warehouse_id   String
  reference_doc  String?
  notes          String?
  status         WorkflowStatus @default(PENDING)
  received_by    String
  received_at    DateTime?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  supplier   Supplier?       @relation(fields: [supplier_id], references: [id])
  receiver   User            @relation(fields: [received_by], references: [id])
  lines      ReceivingLine[]
  qc_records QcRecord[]

  @@index([receiving_type])
  @@index([status])
  @@map("receiving_jobs")
}

model ReceivingLine {
  id               String   @id @default(cuid())
  receiving_job_id String
  product_id       String
  lot_id           String?
  expected_qty     Decimal
  received_qty     Decimal  @default(0)
  bin_id           String?
  notes            String?
  created_at       DateTime @default(now())

  receiving_job ReceivingJob @relation(fields: [receiving_job_id], references: [id])
  product       Product      @relation(fields: [product_id],       references: [id])
  lot           Lot?         @relation(fields: [lot_id],           references: [id])

  @@map("receiving_lines")
}

// ─── QC ──────────────────────────────────────────────────────────────────────

model QcRecord {
  id                String    @id @default(cuid())
  receiving_job_id  String?
  production_job_id String?
  product_id        String
  lot_id            String?
  qty_inspected     Decimal
  qty_passed        Decimal   @default(0)
  qty_failed        Decimal   @default(0)
  result            QcResult  @default(PENDING)
  checklist         Json?
  notes             String?
  certificate_no    String?
  inspected_by      String
  inspected_at      DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  receiving_job  ReceivingJob?  @relation(fields: [receiving_job_id],  references: [id])
  production_job ProductionJob? @relation(fields: [production_job_id], references: [id])
  inspector      User           @relation(fields: [inspected_by],       references: [id])

  @@map("qc_records")
}

// ─── PRODUCTION ──────────────────────────────────────────────────────────────

model ProductionJob {
  id           String         @id @default(cuid())
  job_number   String         @unique
  job_type     String
  product_id   String
  lot_id       String?
  qty_planned  Decimal
  qty_produced Decimal        @default(0)
  warehouse_id String
  status       WorkflowStatus @default(PENDING)
  started_at   DateTime?
  completed_at DateTime?
  assigned_to  String?
  notes        String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  assigned_user     User?                  @relation(fields: [assigned_to], references: [id])
  qc_records        QcRecord[]
  consumption_lines ProductionConsumption[]

  @@index([status])
  @@map("production_jobs")
}

model ProductionConsumption {
  id                String   @id @default(cuid())
  production_job_id String
  product_id        String
  lot_id            String?
  qty_planned       Decimal
  qty_consumed      Decimal  @default(0)
  created_at        DateTime @default(now())

  production_job ProductionJob @relation(fields: [production_job_id], references: [id])

  @@map("production_consumptions")
}

// ─── CUSTOMERS & ORDERS ──────────────────────────────────────────────────────

model Customer {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  name_th    String?
  phone      String?
  email      String?
  address    String?
  line_id    String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  orders Order[]

  @@map("customers")
}

model Order {
  id               String       @id @default(cuid())
  order_number     String       @unique
  channel          OrderChannel
  channel_ref      String?
  customer_id      String?
  status           OrderStatus  @default(PENDING)
  warehouse_id     String?
  shipping_address String?
  notes            String?
  total_amount     Decimal?
  handled_by       String?
  ordered_at       DateTime     @default(now())
  shipped_at       DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  customer Customer?   @relation(fields: [customer_id], references: [id])
  handler  User?       @relation(fields: [handled_by],  references: [id])
  lines    OrderLine[]
  shipment Shipment?

  @@index([channel])
  @@index([status])
  @@index([ordered_at])
  @@map("orders")
}

model OrderLine {
  id          String   @id @default(cuid())
  order_id    String
  product_id  String
  lot_id      String?
  qty_ordered Decimal
  qty_picked  Decimal  @default(0)
  qty_packed  Decimal  @default(0)
  unit_price  Decimal?
  notes       String?
  created_at  DateTime @default(now())

  order   Order   @relation(fields: [order_id],   references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@map("order_lines")
}

// ─── SHIPPING ─────────────────────────────────────────────────────────────────

model Carrier {
  id         String     @id @default(cuid())
  code       String     @unique
  name       String
  name_th    String?
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now())

  shipments Shipment[]

  @@map("carriers")
}

model Shipment {
  id              String         @id @default(cuid())
  shipment_number String         @unique
  order_id        String         @unique
  carrier_id      String?
  tracking_number String?
  status          WorkflowStatus @default(PENDING)
  packed_by       String?
  shipped_by      String?
  packed_at       DateTime?
  shipped_at      DateTime?
  delivered_at    DateTime?
  notes           String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  order     Order        @relation(fields: [order_id],   references: [id])
  carrier   Carrier?     @relation(fields: [carrier_id], references: [id])
  processor User?        @relation(fields: [shipped_by], references: [id])
  boxes     ShipmentBox[]

  @@map("shipments")
}

model ShipmentBox {
  id          String   @id @default(cuid())
  shipment_id String
  box_number  String
  weight      Decimal?
  barcode     String?
  created_at  DateTime @default(now())

  shipment Shipment @relation(fields: [shipment_id], references: [id])

  @@map("shipment_boxes")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  user_id        String
  type           NotificationType
  title          String
  message        String
  reference_type String?
  reference_id   String?
  is_read        Boolean          @default(false)
  created_at     DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read])
  @@index([created_at])
  @@map("notifications")
}

model StockAlertRule {
  id           String   @id @default(cuid())
  product_id   String   @unique
  min_qty      Int
  notify_roles Json
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id])

  @@map("stock_alert_rules")
}

// ─── AUDIT ───────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  user_id      String?
  action       String
  entity_type  String
  entity_id    String?
  old_values   Json?
  new_values   Json?
  ip_address   String?
  performed_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_at])
  @@map("audit_logs")
}
